{
  "name": "slack-notice-action",
  "version": "3.3.0",
  "private": true,
  "description": "A Github Action to notify slack.",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test-for-local": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run build && npm run format && npm run lint && npm run pack && npm test",
    "release": "npm run build && npm run pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonots/slack-notice-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "chat",
    "slack"
  ],
  "author": "sonots",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.2.6",
    "@actions/exec": "^1.0.2",
    "@actions/github": "^9.1.1",
    "@actions/io": "^1.0.1",
    "@actions/tool-cache": "^1.1.2",
    "@slack/webhook": "^7.0.9",
    "semver": "^7.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-github": "^5.0.0",
    "eslint-plugin-jest": "^28.0.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.7.0"
  }
}
